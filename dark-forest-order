<!DOCTYPE html>
<html lang="ru">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Орден Тёмного Леса</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:Arial, sans-serif;
    background:#111;
    color:white;
}

.hero{
    height:70vh;
    background:url("images/1000001659.jpg") center center/cover no-repeat;
    display:flex;
    justify-content:center;
    align-items:center;
    text-align:center;
    position:relative;
}

.hero::before{
    content:"";
    position:absolute;
    top:0;
    left:0;
    width:100%;
    height:100%;
    background:rgba(0,0,0,0.45);
}

.hero-content{
    position:relative;
    z-index:2;
}

.hero h1{
    font-size:60px;
    margin-bottom:15px;
}

.hero p{
    font-size:24px;
}

.container{
    max-width:1000px;
    margin:auto;
    padding:40px 20px;
}

.card{
    background:#1d1d1d;
    border-radius:15px;
    padding:25px;
    margin-bottom:25px;
}

.card h2{
    color:#7cf59c;
    margin-bottom:15px;
}

.characters{
    display:grid;
    gap:15px;
}

.character{
    background:#2a2a2a;
    padding:15px;
    border-radius:10px;
}

.character:hover{
    background:#343434;
}

ul{
    padding-left:20px;
}

li{
    margin-bottom:8px;
}

footer{
    text-align:center;
    padding:30px;
    color:#888;
    border-top:1px solid #222;
}

</style>
</head>
<body>

